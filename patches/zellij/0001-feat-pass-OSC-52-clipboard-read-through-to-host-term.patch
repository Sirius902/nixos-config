From 91411bfab0d279990e69ea747b5785031b832ebe Mon Sep 17 00:00:00 2001
From: Sirius902 <10891979+Sirius902@users.noreply.github.com>
Date: Tue, 12 May 2026 16:30:21 -0700
Subject: [PATCH] feat: forward OSC 52 clipboard-read queries to host terminal
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Forward `\x1b]52;<sel>;?...` queries from panes out to the host terminal
and route the terminal's reply back to the focused pane via the existing
HostQuery forwarding infrastructure. This lets apps inside zellij (e.g.
remote nvim) use OSC 52 paste without zellij adding a second permissions
layer on top of the host terminal's own prompt.

OSC 52 writes (copy) are untouched — those already work via ClipboardProvider.

Refs zellij-org/zellij#2647

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
---
 zellij-server/src/host_query.rs | 15 +++++++++++++++
 zellij-server/src/panes/grid.rs | 12 +++++++++++-
 zellij-server/src/screen.rs     |  1 +
 3 files changed, 27 insertions(+), 1 deletion(-)

diff --git a/zellij-server/src/host_query.rs b/zellij-server/src/host_query.rs
index cf35c9f..0e69861 100644
--- a/zellij-server/src/host_query.rs
+++ b/zellij-server/src/host_query.rs
@@ -65,6 +65,13 @@ pub enum HostQuery {
     /// to the wire it synthesises `\e[?997;{0|1|2}n` directly into the
     /// originating pane's pty.
     ColorPaletteMode,
+    /// `OSC 52 ; <sel> ; ? <term>` — clipboard read (paste) query.
+    /// Forwarded to the host terminal so it can prompt the user and
+    /// reply with the clipboard contents.
+    Osc52Read {
+        selector: String,
+        terminator: OscTerminator,
+    },
 }
 
 impl HostQuery {
@@ -96,6 +103,14 @@ impl HostQuery {
             // bypass `Screen::forward_host_query` for this variant
             // shouldn't be calling `to_query_bytes` on it at all.
             HostQuery::ColorPaletteMode => Vec::new(),
+            HostQuery::Osc52Read {
+                selector,
+                terminator,
+            } => {
+                let mut v = format!("\x1b]52;{};?", selector).into_bytes();
+                v.extend_from_slice(terminator.as_bytes());
+                v
+            },
         }
     }
 }
diff --git a/zellij-server/src/panes/grid.rs b/zellij-server/src/panes/grid.rs
index 9f6134c..ea65fa0 100644
--- a/zellij-server/src/panes/grid.rs
+++ b/zellij-server/src/panes/grid.rs
@@ -3699,7 +3699,17 @@ impl Perform for Grid {
                 let _clipboard = params[1].get(0).unwrap_or(&b'c');
                 match params[2] {
                     b"?" => {
-                        // TBD: paste from own clipboard - currently unsupported
+                        let selector = str::from_utf8(params[1]).unwrap_or("c");
+                        let selector = if selector.is_empty() { "c" } else { selector };
+                        self.pending_forwarded_queries.push(
+                            crate::host_query::HostQuery::Osc52Read {
+                                selector: selector.to_owned(),
+                                terminator:
+                                    crate::host_query::OscTerminator::from_bell_terminated(
+                                        bell_terminated,
+                                    ),
+                            },
+                        );
                     },
                     base64 => {
                         if let Ok(bytes) = base64::decode(base64) {
diff --git a/zellij-server/src/screen.rs b/zellij-server/src/screen.rs
index fd9a701..69671ea 100644
--- a/zellij-server/src/screen.rs
+++ b/zellij-server/src/screen.rs
@@ -2397,6 +2397,7 @@ impl Screen {
                 Some(HostTerminalThemeMode::Light) => b"\x1b[?997;2n".to_vec(),
                 None => Vec::new(),
             },
+            HostQuery::Osc52Read { .. } => Vec::new(),
         }
     }
 
