                 },
+                Ok((InputInstruction::Osc52Response(raw_bytes), _error_context)) => {
+                    // Deliver the raw OSC 52 response to the focused pane's PTY by
+                    // reusing the existing Write action — no new IPC message needed.
+                    // Intentionally mode-agnostic: this isn't user keyboard input,
+                    // it's a reply to a query the focused pane just made.
+                    self.dispatch_action(
+                        Action::Write {
+                            key_with_modifier: None,
+                            bytes: raw_bytes,
+                            is_kitty_keyboard_protocol: false,
+                        },
+                        None,
+                    );
+                },
                 Ok((InputInstruction::StartedParsing, _error_context)) => {
                     self.send_client_instructions
                         .send(ClientInstruction::StartedParsingStdinQuery)
