+    fn forward_osc52_queries(&self, queries: Vec<String>) -> Result<()> {
+        // Forward OSC 52 clipboard-read queries (`\x1b]52;<sel>;?<term>`) emitted
+        // by apps inside a pane out to the host terminal so it can prompt the
+        // user and reply. The reply comes back on the client's stdin and is
+        // routed to the focused pane via `InputInstruction::Osc52Response`.
+        let err_context = || "failed to forward osc52 queries to host terminal".to_string();
+        let mut output = Output::default();
+        let all_clients: HashSet<ClientId> = self
+            .connected_clients_in_app
+            .borrow()
+            .keys()
+            .copied()
+            .collect();
+        output.add_clients(&all_clients, self.link_handler.clone(), None);
+        for raw in queries {
+            output.add_post_vte_instruction_to_multiple_clients(all_clients.iter().copied(), &raw);
+        }
+        let serialized_output = output.serialize().with_context(err_context)?;
+        self.senders
+            .send_to_server(ServerInstruction::Render(Some(serialized_output)))
+            .with_context(err_context)?;
+        Ok(())
+    }
